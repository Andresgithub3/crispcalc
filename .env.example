# CrispCalc environment variables.
# Copy this file to `.env.local` and fill in real values for local dev.
# Vercel production values live in the Vercel dashboard, not here.

# --- Google Analytics 4 --------------------------------------------------
# From analytics.google.com → Admin → Data streams → "Measurement ID".
# Example format: G-XXXXXXXXXX
NEXT_PUBLIC_GA_ID=

# --- Google AdSense ------------------------------------------------------
# From adsense.google.com → Sites → AdSense code. The "ca-pub-..." value.
# Example format: ca-pub-0000000000000000
NEXT_PUBLIC_ADSENSE_CLIENT_ID=

# --- Site URL (for canonicals, sitemap, OG images) -----------------------
# No trailing slash. Change to https://crispcalc.com in production.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
